{
  "name": "bussola-financeira-fe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e:local": "playwright test",
    "test:e2e:local:ui": "playwright test --ui",
    "test:e2e:local:debug": "playwright test --debug",
    "test:e2e:msw": "npm run build && cross-env MOCK_API=true next start & npx wait-on http://localhost:3000 && playwright test; kill-port 3000",
    "test:e2e:msw:ui": "npm run build && cross-env MOCK_API=true next start & npx wait-on http://localhost:3000 && playwright test --ui; kill-port 3000",
    "test:ci": "npm run test -- --ci --coverage --maxWorkers=2",
    "test:e2e:ci": "npm run build && cross-env MOCK_API=true next start & npx wait-on http://localhost:3000 && playwright test --reporter=html; kill-port 3000",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint src",
    "lint:eslint:fix": "eslint --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "jwt-decode": "^4.0.0",
    "next": "^16.1.5",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.1",
    "react-icons": "^5.5.0",
    "react-toastify": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.9.19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.5",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "kill-port": "^2.0.1",
    "msw": "^2.13.3",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
